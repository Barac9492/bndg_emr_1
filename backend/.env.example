# 분당 골든패스 — API Keys
# Copy to .env and fill in your keys

# E-Gen (응급의료포털) API
# Get key at: https://www.data.go.kr/data/15000563/openapi.do
EGEN_API_KEY=

# KMA (기상청) 초단기실황 API
# Get key at: https://www.data.go.kr/data/15084084/openapi.do
KMA_API_KEY=

# ITS (국가교통정보센터) API
# Get key at: https://www.data.go.kr/data/15058068/openapi.do
TRAFFIC_API_KEY=

# Cache TTL (seconds)
CACHE_TTL_EGEN=60
CACHE_TTL_KMA=300
CACHE_TTL_TRAFFIC=120
